set t_Co=256
set background=dark
colorscheme desert
set nocompatible
filetype plugin indent on
syntax on
set nu
set relativenumber

set cursorline
set showmatch
set wildmenu
set showcmd
set scrolloff=8

set tabstop=4
set shiftwidth=4
set expandtab
set smartindent
set autoindent
set cindent

set incsearch
set hlsearch
set ignorecase
set smartcase

set laststatus=2
set statusline=\ %f
set statusline+=\ %m
set statusline+=\ %r
set statusline+=%=
set statusline+=\ %y
set statusline+=\ %l/%L
set statusline+=\ [%c]
